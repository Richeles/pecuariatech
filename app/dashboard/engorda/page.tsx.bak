"use client";

import { useDashboard } from "../DashboardContext";

export const dynamic = 'force-dynamic';

export default function EngordaPage() {
  const { data, loading } = useDashboard();

  if (loading) {
    return <div className="animate-pulse text-[#A7F3D0]/60">Carregando dados da engorda...</div>;
  }

  const gmd = data?.gmd || 0;
  const scorePi = data?.score_pi || 0;
  const capitalScore = data?.capital_score || 0;

  return (
    <div className="space-y-6">
      <h1 className="text-3xl font-bold text-white">Central PecuariaTech – Engorda</h1>
      <p className="text-[#A7F3D0]/60">Performance e conversão animal</p>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div className="bg-[#1A3F2A]/60 rounded-2xl p-6 border border-[#34D399]/20">
          <p className="text-sm text-[#A7F3D0]/50">GMD (kg/dia)</p>
          <p className="text-2xl font-bold text-white">{gmd.toFixed(3)}</p>
        </div>
        <div className="bg-[#1A3F2A]/60 rounded-2xl p-6 border border-[#34D399]/20">
          <p className="text-sm text-[#A7F3D0]/50">Score π</p>
          <p className="text-2xl font-bold text-white">{scorePi.toFixed(1)}</p>
        </div>
        <div className="bg-[#1A3F2A]/60 rounded-2xl p-6 border border-[#34D399]/20">
          <p className="text-sm text-[#A7F3D0]/50">Capital Score</p>
          <p className="text-2xl font-bold text-[#34D399]">{capitalScore.toFixed(1)}</p>
        </div>
      </div>
    </div>
  );
}